# =============================================================================
# GitHubAction 默认配置（可与仓库一并提交；勿在此存放真实密钥）
# 机密、代理账号、API Key 请写在 .env.local（已在 .gitignore）
# 加载顺序：先本文件，再 .env.local（后者覆盖）
# =============================================================================

# --- Microsoft Graph（Graph 取件；密钥建议只放 .env.local）---
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=consumers
GRAPH_CLIENT_SECRET=
GRAPH_REDIRECT_URI=http://localhost:8400/callback

# --- 代理（留空 = 直连；真实账号建议放 .env.local）---
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
PROXY_TYPE=http

# --- BitBrowser ---
BITBROWSER_BASE_URL=http://127.0.0.1:54345

# --- 以下为可选；也可只在 .env.local 里打开 ---
# BITBROWSER_API_KEY=
# CAPTCHA_MANUAL_WAIT=1
# CAPTCHA_401_ABORT_AFTER=1
